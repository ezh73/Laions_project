# ============================================================
# Laions 프로젝트 환경 변수 템플릿
# 이 파일을 .env로 복사하고 실제 값으로 채워서 사용하세요.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://user:password@db:5432/laions_db"
DB_USER=user
DB_PASSWORD=password
DB_NAME=laions_db

# --- Admin Mode ---
ADMIN_MODE=false
ADMIN_DATE="2025-08-15"

# --- Gemini AI ---
GEMINI_API_KEY="your_gemini_api_key"

# --- Frontend ---
# 로컬 개발: http://localhost:8001
# Docker (Nginx 프록시): 빈 문자열 (상대 경로 /api/... 사용)
REACT_APP_API_BASE_URL='http://localhost:8001'

# --- Supabase (Firebase 대체) ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
REACT_APP_SUPABASE_URL="https://your-project.supabase.co"
REACT_APP_SUPABASE_ANON_KEY="your_anon_key"
